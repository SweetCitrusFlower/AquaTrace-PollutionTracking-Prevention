{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["es2017"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["App.tsx", "src/**/*.ts", "src/**/*.tsx"]
}